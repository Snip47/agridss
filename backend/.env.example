# AgriDSS v2 Environment Variables

# Database (Supabase PostgreSQL for production)
# DATABASE_URL=sqlite:///./agridss.db
DATABASE_URL=postgresql://user:password@host.supabase.co:5432/postgres

# JWT Secret (change this!)
SECRET_KEY=agridss-kenya-2024-change-this-secret

# ============================================================
# FREE AI API OPTIONS (No credit card needed!)
# ============================================================

# OPTION 1: Google Gemini Flash - FREE 1,500 requests/day
# Get your FREE key at: https://aistudio.google.com/apikey
# Steps: Go to site > Sign in with Google > Create API Key > Copy key below
GEMINI_API_KEY=your-gemini-api-key-here

# OPTION 2: Groq - FREE 14,400 requests/day (Llama 3.3 70B model)
# Get your FREE key at: https://console.groq.com
# Steps: Sign up > Create API Key > Copy key below
GROQ_API_KEY=your-groq-api-key-here

# You can configure BOTH for redundancy. Gemini is used by default.
# ============================================================
